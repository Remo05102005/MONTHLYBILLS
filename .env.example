# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Scheduler Server Configuration
REACT_APP_SCHEDULER_SERVER_URL=http://localhost:3001

# Other API Keys
REACT_APP_OPENAI_API_KEY=your_openai_api_key
REACT_APP_GOOGLE_AI_API_KEY=your_google_ai_api_key

# Telegram Bot Configuration
# Get your bot token from: https://t.me/BotFather
REACT_APP_TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Admin Configuration for Database Backup
# Admin's Telegram Chat ID (for receiving database backups via Telegram)
# Get your chat ID by messaging your bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
REACT_APP_ADMIN_CHAT_ID=your_telegram_chat_id
